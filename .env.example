# 请复制此文件为 .env 并填入您的配置

# ========== 数据库配置 ==========
DB_HOST=119.45.182.166
DB_PORT=3306
DB_NAME=oldz
DB_USER=oldz
DB_PASSWORD=your_db_password

# ========== JWT 配置 ==========
JWT_SECRET=your_jwt_secret_key

# ========== API 地址 ==========
# 前端直连 API 时使用（Capacitor 原生 App / Electron 生产模式）
# 浏览器 dev 模式无需配置，Vite 代理自动转发 /api → localhost:PORT
VITE_API_BASE_URL=http://localhost:3001/api

# ========== 服务端口 ==========
PORT=3001

# ========== 阿里云OSS配置 ==========
# OSS Region，如 oss-cn-hangzhou
VITE_OSS_REGION=oss-cn-hangzhou

# OSS AccessKey ID
VITE_OSS_ACCESS_KEY_ID=your_access_key_id

# OSS AccessKey Secret
VITE_OSS_ACCESS_KEY_SECRET=your_access_key_secret

# OSS Bucket名称
VITE_OSS_BUCKET=old-z-files

# OSS Endpoint
VITE_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
